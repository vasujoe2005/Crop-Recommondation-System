{
  "expo": {
    "name": "GeoCrop AI",
    "slug": "geocrop-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/geocrop-ai-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/geocrop-ai-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1713"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow GeoCrop AI to access your location for farm selection."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow GeoCrop AI to access your location for farm selection."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f1713",
        "foregroundImage": "./assets/geocrop-ai-logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/geocrop-ai-logo.png"
    }
  }
}
